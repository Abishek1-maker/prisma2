
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model Property {
  id          Int      @id @default(autoincrement())
  name         String
  description     String   
  price        Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features  Propertyfeatures?
  
  user     User? @relation(fields:[userId], references:[id])
  userId   Int?  //<-foreign key optional
  
  UserProperties UserProperty[]
}
model Propertyfeatures{
  id            Int @id @default(autoincrement())
  bedroom       Int
  hall          Boolean?
  kitchen       Boolean?
  bathroom      Boolean?
                                //foreignkey        proprtytable'id'
  property      Property? @relation(fields:[propertyId] , references:[id])
  propertyId    Int @unique  //<--1 to 1

}

model User{
  id        Int @id @default(autoincrement())
  name      String
  password String?
  hashedRefreshToken String?    //<-----------Step 1--------------
  email     String  @unique
  number    String?
  properties  Property[]

  UserProperties    UserProperty[]  //<-connects join table
}

model UserProperty{

user    User    @relation(fields:[userId], references:[id])
userId     Int

propertyId  Int
property   Property @relation(fields:[propertyId], references:[id])

@@id([userId,propertyId])       //<-- composite primary key imp to many to many relation
   
}
